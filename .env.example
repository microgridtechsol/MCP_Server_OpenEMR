# Server Configuration
PORT=8082
NODE_ENV=development

# OpenEMR Configuration
OPENEMR_BASE_URL=https://your-openemr-instance.com
OPENEMR_CLIENT_ID=your-client-id
OPENEMR_CLIENT_SECRET=your-client-secret
OPENEMR_REDIRECT_URI=http://127.0.0.1:8082/oauth/callback
OPENEMR_API_PREFIX=/apis/default/api

# JWT Configuration
JWT_ALGORITHMS=RS256

# Token Refresh Configuration
# Time before expiry to trigger automatic token refresh (in milliseconds)
# Default: 300000 (5 minutes)
TOKEN_REFRESH_THRESHOLD=300000

# Session Store Configuration
# Options: 'memory', 'redis', 'sql' (sql coming soon)
SESSION_STORE=memory

# Session TTL (Time To Live)
# For Redis: seconds (default: 3600 = 1 hour)
# For Memory: milliseconds (default: 3600000 = 1 hour)
SESSION_TTL=3600

# Redis Configuration (only needed if SESSION_STORE=redis)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# SQL Configuration (coming soon - only needed if SESSION_STORE=sql)
# DB_TYPE=postgres
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=openemr_sessions
# DB_USER=your-db-user
# DB_PASSWORD=your-db-password
